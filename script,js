// Selecionando os elementos da página
const botao = document.getElementById('meuBotao');
const mensagem = document.getElementById('mensagem');

// Adicionando o evento de clique ao botão
botao.addEventListener('click', () => {
    // Liga/Desliga a classe 'mostrar' no parágrafo da mensagem
    mensagem.classList.toggle('mostrar');
    
    // Altera o texto do botão para dar um feedback visual
    if (mensagem.classList.contains('mostrar')) {
        botao.textContent = 'Fechar';
    } else {
        botao.textContent = 'Clique Aqui';
    }
});
